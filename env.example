# =====================================================
# Tabela — Environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.
# =====================================================

# -- Phase 1 (data pipeline) ----------------------------------

# Football-Data.org — free token from https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Anthropic — for editorial generation. https://console.anthropic.com
ANTHROPIC_API_KEY=

# -- Phase 1 (scheduling) -------------------------------------

# Trigger.dev v3 — https://trigger.dev/
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# -- Phase 3 (storage) ----------------------------------------

# Supabase — https://supabase.com/
# New key format: sb_publishable_... and sb_secret_... are drop-in replacements
# for the legacy anon and service_role keys. Env var names stay the same for
# ecosystem compatibility.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_PROJECT_REF=

# -- Website --------------------------------------------------

# Public URL of the deployed site (no trailing slash).
# Local: http://localhost:3000  Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=

# Display name used in metadata / share previews.
NEXT_PUBLIC_APP_NAME=Tabela

# -- Phase 5 (audio) ------------------------------------------

# ElevenLabs — https://elevenlabs.io/
# SDK package: @elevenlabs/elevenlabs-js
ELEVENLABS_API_KEY=
# Voice: George — warm, measured, British-accented. Verify ID in the ElevenLabs
# dashboard before going live; IDs can change when voices are updated.
ELEVENLABS_VOICE_ID=jsCqWAovK2LkecY7zXl4
